# Expo only exposes env vars to the JS bundle when they start with EXPO_PUBLIC_
# Copy your Firebase values from the web app (.env.local) into these.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: AI itinerary generation (fallback itinerary used if missing)
EXPO_PUBLIC_GEMINI_API_KEY=
